{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tended",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "account_id": "65fb048fa9b4fb99f6473038c393d6a0",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "tended"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tended-db",
      "database_id": "3a4387f9-9220-40b4-998c-a682565b825c",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "FILES",
      "bucket_name": "tended-files"
    }
  ],
  // Browser Rendering — server-side headless auto-check for the gov-audit
  // feature (lib/gov-audit-browser.ts). Absent in local dev / opennextjs, where
  // the module degrades to a plain-fetch fallback.
  "browser": {
    "binding": "BROWSER"
  },
  "vars": {
    "OPENROUTER_MODEL": "google/gemini-2.0-flash-exp:free",
    "OPENROUTER_SITE_URL": "https://tended.xkbtrjm2bm.workers.dev",
    "OPENROUTER_APP_NAME": "Tended",
    "FIREBASE_PROJECT_ID": "volunteer-online-bcfa9",
    "APP_ORIGIN": "https://tended.xkbtrjm2bm.workers.dev"
  },
  // Scheduled maintenance jobs (UTC). NOTE: the current @opennextjs/cloudflare
  // build does NOT emit a `scheduled()` handler — its generated
  // `.open-next/worker.js` default-exports `fetch` only — so declaring these
  // crons is necessary but NOT sufficient. They must be wired to an
  // authenticated internal route (the cron worker GETs it) before they fire.
  // See the "Scheduled jobs / cron" section of README.md for the exact wiring
  // (the route is not yet implemented — these crons are a documented no-op
  // until then).
  //   08:00 UTC daily   → Open Prices retry-queue drain (lib/audit-pipeline.ts:retryOpenPricesQueue)
  //   03:30 UTC Mondays → cap calibration (app/api/admin/calibrate-caps)
  "triggers": {
    "crons": ["0 8 * * *", "30 3 * * MON"]
  }
  // Secrets (NOT here — set with `wrangler secret put`): PII_ENCRYPTION_KEY (required —
  // PII storage throws without it), OPENROUTER_API_KEY (AI review; falls back to manual),
  // RESEND_API_KEY + EMAIL_FROM (org team-invite email). DEMO_MODE is intentionally unset
  // so production has no seeding, no /admin/reset, and no onboarding skips. See docs/DEPLOYMENT.md.
}
